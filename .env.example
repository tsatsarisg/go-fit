# -----------------------------------------------------------------------------
# go-fit environment variables
#
# Copy this file to .env and fill in the values. .env is gitignored.
#   cp .env.example .env
# -----------------------------------------------------------------------------

# --- Required -----------------------------------------------------------------

# Target environment. Controls log format, JSON pretty-printing, and SSL
# enforcement on DATABASE_URL. One of: development | production
APP_ENV=development

# HTTP listen port. Default 8080 if unset.
PORT=8080

# Primary DB connection string. If set, this wins over the discrete PG*
# fallbacks below. In production, sslmode=disable is rejected.
#   Examples:
#     postgres://user:pass@host:5432/dbname?sslmode=disable   (dev)
#     postgres://user:pass@host:5432/dbname?sslmode=require   (prod)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres?sslmode=disable

# --- Optional (used only when DATABASE_URL is NOT set) ------------------------

# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=postgres
# PGSSLMODE=disable        # defaults: disable in dev, require in production
